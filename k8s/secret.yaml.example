# Copy this file to secret.yaml and fill in your Telegram API credentials.
# Get your api_id and api_hash from https://my.telegram.org/apps
#
# Then: kubectl apply -f k8s/
#
# The config is mounted as /data/config.toml inside the container.
# All other fields below have sane defaults — only api_id and api_hash are required.
apiVersion: v1
kind: Secret
metadata:
  name: pyrobud-config
  namespace: pyrobud
stringData:
  config.toml: |
    version = 11

    [telegram]
    api_id = 123456
    api_hash = "YOUR_API_HASH_HERE"
    session_name = "main"

    [bot]
    default_prefix = "."
    db_path = "main.db"
    report_errors = false
    report_username = false
    sentry_dsn = ""
    response_mode = "edit"
    overflow_mode = "truncate"
    overflow_page_limit = 4
    redact_responses = true

    [asyncio]
    disable_uvloop = false
    debug = false
